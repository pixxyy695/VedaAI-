# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Backend
PORT=4000
WEB_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/vedai
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_OUTPUT_TOKENS=2500
OPENAI_SOURCE_TEXT_LIMIT=3500
MAX_GENERATION_QUESTIONS=12
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
RUN_WORKER_IN_API=false

# Set these to true only when you want the app to run without local services.
USE_MEMORY_DB=false
USE_MEMORY_QUEUE=false
